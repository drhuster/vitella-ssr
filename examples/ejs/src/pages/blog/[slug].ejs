<% const posts = {
  'hello-world': { title: 'Hello World', body: 'This is my first post.' },
  'ssr-explained': { title: 'SSR Explained', body: 'Server-side rendering renders HTML on the server before sending it to the client.' },
  'vanilla-js': { title: 'EJS with Vitella', body: 'EJS templates compiled to standalone functions via the Vitella SSR adapter.' },
} %>

<main>
  <article>
    <h1><%= posts[slug] ? posts[slug].title : 'Not Found' %></h1>
    <p><%= posts[slug] ? posts[slug].body : 'Post not found.' %></p>
  </article>
  <a href="/blog">Back to Blog</a>
</main>
